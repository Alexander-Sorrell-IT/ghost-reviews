# Copy this file to .env. Leave a key BLANK to run in free sample mode.
# Fill NIMBLE_API_KEY to pull live web reviews; fill ANTHROPIC_API_KEY to
# upgrade the teardown from the free rule engine to Claude.
NIMBLE_API_KEY=
ANTHROPIC_API_KEY=

# Optional overrides
# GHOST_MODEL=claude-sonnet-4-6
# GHOST_PRODUCT=Acme Wireless Earbuds
# GHOST_SAMPLE=1   # force sample mode even if keys are set
